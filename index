<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Buscador de Contactos — Business One</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root{
    --navy:#0E1C3D;
    --blue:#2454E0;
    --blue-deep:#1339B0;
    --blue-light:#5B8DEF;
    --blue-pale:#EEF3FE;
    --bg:#F5F7FC;
    --surface:#FFFFFF;
    --border:#E3E8F5;
    --text:#131A2E;
    --text-dim:#727C99;
    --text-faint:#A6AFC6;
    --radius:16px;
    --mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    --font: 'Poppins', -apple-system, BlinkMacSystemFont, sans-serif;
  }
  *{box-sizing:border-box;}
  body{
    margin:0; font-family:var(--font); background:var(--bg); color:var(--text);
    min-height:100vh; -webkit-font-smoothing:antialiased;
  }

  /* Top bar */
  .topbar{
    background:var(--surface); border-bottom:1px solid var(--border);
    padding:16px 28px; display:flex; align-items:center; justify-content:space-between;
    position:sticky; top:0; z-index:20;
  }
  .brand{display:flex; align-items:center; gap:10px;}
  .brand-icon{
    width:34px; height:34px; border-radius:9px;
    background:linear-gradient(135deg, var(--blue) 0%, var(--blue-deep) 100%);
    display:flex; align-items:center; justify-content:center; flex-shrink:0;
    box-shadow:0 4px 10px rgba(36,84,224,.28);
  }
  .brand-name{font-weight:700; font-size:15.5px; color:var(--navy); letter-spacing:-.01em;}
  .brand-sub{font-size:11.5px; color:var(--text-dim); font-weight:500;}
  .count-pill{
    background:var(--blue-pale); color:var(--blue-deep); font-weight:600; font-size:13px;
    padding:7px 14px; border-radius:999px; white-space:nowrap;
  }
  .count-pill b{font-family:var(--mono); font-weight:700;}

  /* Search hero */
  .search-hero{max-width:760px; margin:0 auto; padding:44px 24px 8px; text-align:center;}
  .search-hero h1{
    font-size:26px; font-weight:700; color:var(--navy); margin:0 0 6px; letter-spacing:-.02em;
  }
  .search-hero p{color:var(--text-dim); font-size:14.5px; margin:0 0 26px; font-weight:400;}

  .search-box{
    background:var(--surface); border-radius:14px; display:flex; align-items:center;
    padding:5px 6px 5px 18px; border:1.5px solid var(--border);
    box-shadow:0 8px 24px rgba(19,26,46,.06);
    transition:border-color .15s ease, box-shadow .15s ease;
  }
  .search-box:focus-within{
    border-color:var(--blue-light);
    box-shadow:0 0 0 4px var(--blue-pale), 0 8px 24px rgba(36,84,224,.12);
  }
  .search-box svg.icon-search{flex-shrink:0; color:var(--text-faint);}
  #q{
    flex:1; border:none; outline:none; font-size:15.5px; padding:15px 12px;
    background:transparent; color:var(--text); font-family:var(--font); font-weight:500;
  }
  #q::placeholder{color:var(--text-faint); font-weight:400;}
  .search-btn{
    width:42px; height:42px; border-radius:10px; border:none; flex-shrink:0;
    background:linear-gradient(135deg, var(--blue) 0%, var(--blue-deep) 100%);
    color:#fff; display:flex; align-items:center; justify-content:center; cursor:pointer;
  }
  .kbd{
    font-family:var(--mono); font-size:11px; color:var(--text-faint);
    background:var(--bg); border:1px solid var(--border);
    padding:3px 7px; border-radius:6px; margin-right:8px; white-space:nowrap; font-weight:500;
  }

  main{max-width:760px; margin:0 auto; padding:14px 24px 80px;}

  .hint{color:var(--text-dim); font-size:14px; text-align:center; padding:60px 20px; font-weight:400;}
  .hint b{color:var(--navy); font-weight:600;}

  .results-toolbar{
    display:flex; justify-content:space-between; align-items:center;
    padding:6px 2px 12px; font-size:13px; color:var(--text-dim); font-weight:500;
  }

  .results{display:flex; flex-direction:column; gap:8px;}
  .result-card{
    background:var(--surface); border:1px solid var(--border); border-radius:13px;
    padding:12px 14px; cursor:pointer; transition:transform .12s ease, box-shadow .12s ease, border-color .12s ease;
    display:flex; align-items:center; gap:13px;
  }
  .result-card:hover{
    border-color:var(--blue-light); box-shadow:0 6px 18px rgba(36,84,224,.10);
    transform:translateY(-1px);
  }
  .avatar{
    width:42px; height:42px; border-radius:11px; flex-shrink:0;
    display:flex; align-items:center; justify-content:center;
    color:#fff; font-weight:700; font-size:14.5px; letter-spacing:.01em;
  }
  .result-main{min-width:0; flex:1;}
  .result-name{font-weight:600; font-size:14.5px; color:var(--navy); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;}
  .result-sub{font-size:12.5px; color:var(--text-dim); margin-top:1px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; font-weight:400;}
  .result-tags{display:flex; gap:6px; flex-shrink:0; align-items:center;}
  .tag{
    font-family:var(--mono); font-size:10.5px; padding:4px 8px; border-radius:6px;
    background:var(--blue-pale); color:var(--blue-deep); border:1px solid #DCE6FC;
    white-space:nowrap; font-weight:600;
  }
  .arrow{color:var(--text-faint); flex-shrink:0;}

  .loading{display:flex; align-items:center; gap:10px; color:var(--text-dim); font-size:13.5px; padding:40px 0; justify-content:center; font-weight:500;}
  .spinner{width:15px; height:15px; border:2px solid var(--border); border-top-color:var(--blue); border-radius:50%; animation:spin .7s linear infinite;}
  @keyframes spin{to{transform:rotate(360deg);}}

  /* Modal */
  .overlay{
    position:fixed; inset:0; background:rgba(14,28,61,.5); backdrop-filter:blur(2px);
    display:none; align-items:flex-start; justify-content:center; padding:40px 20px; z-index:50;
    overflow-y:auto;
  }
  .overlay.open{display:flex;}
  .modal{
    background:var(--surface); border-radius:18px; width:100%; max-width:520px;
    box-shadow:0 24px 60px rgba(14,28,61,.3); overflow:hidden;
    animation:pop .16s ease;
  }
  @keyframes pop{from{transform:translateY(8px); opacity:0;} to{transform:translateY(0); opacity:1;}}
  .modal-header{
    padding:22px 22px 16px; display:flex; justify-content:space-between; align-items:flex-start; gap:12px;
  }
  .modal-header-left{display:flex; gap:12px; align-items:center; min-width:0;}
  .modal-header h2{margin:0; font-size:17px; color:var(--navy); font-weight:700; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;}
  .modal-header .src{font-size:12px; color:var(--text-dim); font-weight:500; margin-top:2px;}
  .close-btn{
    background:var(--bg); border:none; color:var(--text-dim); width:30px; height:30px;
    border-radius:8px; cursor:pointer; font-size:14px; line-height:1; flex-shrink:0;
  }
  .close-btn:hover{background:var(--border); color:var(--text);}
  .modal-body{padding:2px 22px 8px; max-height:56vh; overflow-y:auto;}
  .field-row{
    display:flex; justify-content:space-between; gap:16px; padding:10px 0;
    border-bottom:1px solid var(--border); font-size:13.5px;
  }
  .field-row:last-child{border-bottom:none;}
  .field-label{color:var(--text-dim); flex-shrink:0; width:42%; font-weight:600;}
  .field-value{color:var(--text); text-align:right; word-break:break-word; font-weight:500; font-size:13.5px;}
  .field-value.no-data{color:var(--text-faint); font-style:italic; font-weight:400;}
  .modal-actions{display:flex; gap:8px; padding:14px 22px 22px; flex-wrap:wrap;}
  .action-btn{
    font-size:12.5px; padding:9px 13px; border-radius:9px; border:1px solid var(--border);
    background:var(--bg); color:var(--navy); text-decoration:none; font-weight:600;
    display:flex; align-items:center; gap:6px;
  }
  .action-btn:hover{background:var(--blue); color:#fff; border-color:var(--blue);}

  .config-warning{
    max-width:760px; margin:16px auto 0; padding:12px 24px; background:#FFF6E8;
    border:1px solid #F0D9A8; color:#7A5A16; font-size:13px; border-radius:10px; font-weight:500;
  }

  @media (max-width:600px){
    .topbar{padding:14px 16px;}
    .search-hero{padding:32px 16px 8px;}
    .result-tags{display:none;}
  }
</style>
</head>
<body>

<div class="topbar">
  <div class="brand">
    <div class="brand-icon">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.3"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    </div>
    <div>
      <div class="brand-name">Contactos B1</div>
      <div class="brand-sub">CRM Business One</div>
    </div>
  </div>
  <div class="count-pill" id="countPill" style="display:none;"><b id="mTotal">0</b> contactos</div>
</div>

<div class="search-hero">
  <h1>Buscador de contactos</h1>
  <p>Nombre, empresa, RUC, correo, teléfono o LinkedIn — en un solo lugar.</p>
  <div class="search-box">
    <svg class="icon-search" width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input id="q" type="text" placeholder="Buscar por nombre, empresa, RUC, correo..." autocomplete="off">
    <span class="kbd">/</span>
    <button class="search-btn" onclick="document.getElementById('q').focus()">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    </button>
  </div>
</div>

<main>
  <div id="configWarning" class="config-warning" style="display:none;">
    Falta configurar la URL del Web App de Apps Script. Edita <code>API_URL</code> en este archivo.
  </div>
  <div id="content">
    <div class="hint">Escribe al menos <b>2 caracteres</b> para buscar.</div>
  </div>
</main>

<div class="overlay" id="overlay">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-header-left">
        <div class="avatar" id="modalAvatar">—</div>
        <div>
          <h2 id="modalTitle">—</h2>
          <div class="src" id="modalSrc"></div>
        </div>
      </div>
      <button class="close-btn" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-body" id="modalBody"></div>
    <div class="modal-actions" id="modalActions"></div>
  </div>
</div>

<script>
// ============================================================
// CONFIGURACIÓN: pega aquí la URL de tu Web App de Apps Script
// (Deploy > New deployment > Web app > copiar URL)
// ============================================================
const API_URL = 'https://script.google.com/macros/s/AKfycbzM2tNQI5LWyV7Xqu8ANrr0S7fUt6sZC_NvZO7bc1QMdji4m0EoBQvsHteFIxOsjYTk/exec';

const AVATAR_COLORS = ['#2454E0', '#1339B0', '#4C6FE0', '#0E2A80', '#5B8DEF', '#0E1C3D'];

const qInput = document.getElementById('q');
const content = document.getElementById('content');
const overlay = document.getElementById('overlay');

if (!API_URL || API_URL.indexOf('PEGA_AQUI') !== -1) {
  document.getElementById('configWarning').style.display = 'block';
}

document.addEventListener('keydown', (e) => {
  if (e.key === '/' && document.activeElement !== qInput) {
    e.preventDefault(); qInput.focus();
  }
  if (e.key === 'Escape') closeModal();
});

let debounceTimer;
qInput.addEventListener('input', () => {
  clearTimeout(debounceTimer);
  const term = qInput.value.trim();
  if (term.length < 2) {
    content.innerHTML = '<div class="hint">Escribe al menos <b>2 caracteres</b> para buscar.</div>';
    return;
  }
  content.innerHTML = '<div class="loading"><span class="spinner"></span> Buscando...</div>';
  debounceTimer = setTimeout(() => runSearch(term), 300);
});

async function runSearch(term) {
  try {
    const res = await fetch(`${API_URL}?action=search&q=${encodeURIComponent(term)}`);
    const json = await res.json();
    if (!json.ok) throw new Error(json.error || 'Error desconocido');
    renderResults(json.data, term);
  } catch (err) {
    content.innerHTML = `<div class="hint">No se pudo buscar: ${escapeHtml(err.message)}</div>`;
  }
}

function initials(nombre, apellido, empresa) {
  const a = (nombre || '').trim()[0] || '';
  const b = (apellido || '').trim()[0] || '';
  if (a || b) return (a + b).toUpperCase();
  return ((empresa || '?').trim()[0] || '?').toUpperCase();
}

function colorFor(str) {
  let h = 0;
  for (let i = 0; i < str.length; i++) h = str.charCodeAt(i) + ((h << 5) - h);
  return AVATAR_COLORS[Math.abs(h) % AVATAR_COLORS.length];
}

function renderResults(rows, term) {
  if (!rows.length) {
    content.innerHTML = `<div class="hint">No se encontraron resultados para "<b>${escapeHtml(term)}</b>".</div>`;
    return;
  }
  const toolbar = `<div class="results-toolbar"><span>${rows.length} resultado${rows.length === 1 ? '' : 's'}</span></div>`;
  const cards = rows.map(r => {
    const nombreCompleto = [r.nombre, r.apellido].filter(Boolean).join(' ') || r.empresa || '(sin nombre)';
    const sub = [r.cargo, r.empresa].filter(Boolean).join(' · ');
    const ini = initials(r.nombre, r.apellido, r.empresa);
    const bg = colorFor(nombreCompleto);
    return `
      <div class="result-card" onclick="openDetail('${escapeAttr(r.id)}')">
        <div class="avatar" style="background:${bg}">${ini}</div>
        <div class="result-main">
          <div class="result-name">${escapeHtml(nombreCompleto)}</div>
          <div class="result-sub">${escapeHtml(sub || '—')}</div>
        </div>
        <div class="result-tags">
          ${r.ruc ? `<span class="tag">RUC ${escapeHtml(r.ruc)}</span>` : ''}
          ${r.origen ? `<span class="tag">${escapeHtml(r.origen)}</span>` : ''}
        </div>
        <svg class="arrow" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      </div>`;
  }).join('');
  content.innerHTML = toolbar + `<div class="results">${cards}</div>`;
}

async function openDetail(id) {
  overlay.classList.add('open');
  document.getElementById('modalTitle').textContent = 'Cargando...';
  document.getElementById('modalSrc').textContent = '';
  document.getElementById('modalAvatar').textContent = '—';
  document.getElementById('modalAvatar').style.background = 'var(--text-faint)';
  document.getElementById('modalActions').innerHTML = '';
  document.getElementById('modalBody').innerHTML = '<div class="loading"><span class="spinner"></span> Cargando detalle...</div>';

  try {
    const res = await fetch(`${API_URL}?action=detail&id=${encodeURIComponent(id)}`);
    const json = await res.json();
    if (!json.ok) throw new Error(json.error || 'Error desconocido');
    renderDetail(json.data);
  } catch (err) {
    document.getElementById('modalBody').innerHTML = `<div class="hint">${escapeHtml(err.message)}</div>`;
  }
}

function renderDetail(detail) {
  const campos = detail.campos || [];
  const getVal = (labelParts) => {
    const f = campos.find(c => labelParts.some(l => c.campo.toLowerCase().includes(l)));
    return f && f.valor !== null ? String(f.valor) : '';
  };
  const nombre = [getVal(['nombre']), getVal(['apellido'])].filter(Boolean).join(' ') || getVal(['empresa']) || 'Detalle';
  const correo = getVal(['correo', 'email', 'mail']);
  const tel = getVal(['telefono', 'celular', 'whatsapp']);
  const linkedin = getVal(['linkedin']);
  const origen = getVal(['origen']);

  document.getElementById('modalTitle').textContent = nombre;
  document.getElementById('modalSrc').textContent = origen ? `Origen: ${origen}` : '';
  document.getElementById('modalAvatar').textContent = initials(getVal(['nombre']), getVal(['apellido']), getVal(['empresa']));
  document.getElementById('modalAvatar').style.background = colorFor(nombre);

  const actions = [];
  if (correo) actions.push(`<a class="action-btn" href="mailto:${escapeAttr(correo)}">✉ Correo</a>`);
  if (tel) actions.push(`<a class="action-btn" href="https://wa.me/${escapeAttr(tel.replace(/\\D/g,''))}" target="_blank">💬 WhatsApp</a>`);
  if (linkedin) actions.push(`<a class="action-btn" href="${escapeAttr(linkedin.startsWith('http') ? linkedin : 'https://'+linkedin)}" target="_blank">🔗 LinkedIn</a>`);
  document.getElementById('modalActions').innerHTML = actions.join('');

  const rows = campos.map(c => {
    const sinDato = c.valor === null || c.valor === undefined || String(c.valor).trim() === '';
    return `
    <div class="field-row">
      <div class="field-label">${escapeHtml(c.campo)}</div>
      <div class="field-value${sinDato ? ' no-data' : ''}">${sinDato ? 'No datos' : escapeHtml(String(c.valor))}</div>
    </div>`;
  }).join('');
  document.getElementById('modalBody').innerHTML = rows || '<div class="hint">Sin datos.</div>';
}

function closeModal() { overlay.classList.remove('open'); }
overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });

async function loadCount() {
  if (!API_URL || API_URL.indexOf('PEGA_AQUI') !== -1) return;
  try {
    const res = await fetch(`${API_URL}?action=stats`);
    const json = await res.json();
    if (!json.ok) return;
    document.getElementById('mTotal').textContent = json.data.total;
    document.getElementById('countPill').style.display = 'inline-block';
  } catch (e) { /* silencioso */ }
}
loadCount();

function escapeHtml(str) {
  return String(str).replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
}
function escapeAttr(str) { return escapeHtml(str).replace(/"/g, '&quot;'); }
</script>

</body>
</html>
